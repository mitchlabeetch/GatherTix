{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Next.js",
  "extends": "./base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "jsx": "preserve",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "noEmit": true,
    "incremental": true,
    "resolveJsonModule": true,
    "strictNullChecks": true
  },
  "include": ["src", "next-env.d.ts"],
  "exclude": ["node_modules"]
}
