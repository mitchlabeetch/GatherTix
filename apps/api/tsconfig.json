{
  "extends": "@ticketing/typescript-config/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@ticketing/database": ["../../packages/database/src"],
      "@ticketing/shared": ["../../packages/shared/src"],
      "@ticketing/email": ["../../packages/email/src"],
      "@ticketing/pdf": ["../../packages/pdf/src"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
