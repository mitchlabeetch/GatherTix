{
  "name": "@ticketing/email",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./templates/*": {
      "import": "./dist/templates/*.js",
      "types": "./dist/templates/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "email dev --port 3002",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@react-email/components": "^0.0.25",
    "@react-email/render": "^1.0.1",
    "react-email": "^3.0.1",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@ticketing/eslint-config": "workspace:*",
    "@ticketing/typescript-config": "workspace:*",
    "@types/node": "^20.16.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "eslint": "^8.57.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
