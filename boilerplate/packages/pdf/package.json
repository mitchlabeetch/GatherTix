{
  "name": "@ticketing/pdf",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./templates/*": {
      "import": "./dist/templates/*.js",
      "types": "./dist/templates/*.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.0.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@ticketing/eslint-config": "workspace:*",
    "@ticketing/typescript-config": "workspace:*",
    "@types/node": "^20.16.11",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.11",
    "eslint": "^8.57.1",
    "react": "^18.3.1",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  }
}
