// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User & Authentication Models
// ============================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  password  String?  // Null for OAuth users
  avatar    String?
  role      UserRole @default(USER)
  status    UserStatus @default(ACTIVE)
  
  // Email verification
  emailVerified Boolean @default(false) @map("email_verified")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  lastLoginAt DateTime? @map("last_login_at")
  
  // Relations
  sessions      Session[]
  organizations OrganizationMember[]
  orders        Order[]
  auditLogs     AuditLog[]
  webhooks      Webhook[]
  
  @@index([email])
  @@index([status])
  @@index([role])
  @@map("users")
}

model Session {
  id        String   @id
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  
  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

// ============================================
// Organization Models
// ============================================

model Organization {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  logo        String?
  website     String?
  email       String?
  phone       String?
  
  // Address
  address     String?
  city        String?
  state       String?
  country     String?
  postalCode  String?  @map("postal_code")
  
  // Settings
  settings    Json?    @default("{}")
  
  // Status
  status      OrganizationStatus @default(ACTIVE)
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // Relations
  members     OrganizationMember[]
  events      Event[]
  templates   Template[]
  webhooks    Webhook[]
  apiKeys     ApiKey[]
  
  @@index([slug])
  @@index([status])
  @@map("organizations")
}

model OrganizationMember {
  id             String              @id @default(cuid())
  organizationId String              @map("organization_id")
  userId         String              @map("user_id")
  role           OrganizationMemberRole @default(MEMBER)
  permissions    String[]            @default([])
  
  // Timestamps
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  
  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

// ============================================
// Event Models
// ============================================

model Event {
  id          String   @id @default(cuid())
  organizationId String @map("organization_id")
  slug        String
  title       String
  description String?  @db.Text
  image       String?
  
  // Event details
  startDate   DateTime @map("start_date")
  endDate     DateTime @map("end_date")
  timezone    String   @default("UTC")
  
  // Location
  venueName   String?  @map("venue_name")
  address     String?
  city        String?
  state       String?
  country     String?
  postalCode  String?  @map("postal_code")
  latitude    Float?
  longitude   Float?
  isVirtual   Boolean  @default(false) @map("is_virtual")
  virtualUrl  String?  @map("virtual_url")
  
  // Settings
  maxAttendees Int?    @map("max_attendees")
  isPublic     Boolean @default(true) @map("is_public")
  status       EventStatus @default(DRAFT)
  
  // Template reference
  templateId   String?  @map("template_id")
  
  // Timestamps
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  publishedAt  DateTime? @map("published_at")
  
  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template     Template?    @relation(fields: [templateId], references: [id])
  ticketTypes  TicketType[]
  orders       Order[]
  checkIns     CheckIn[]
  
  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([status])
  @@index([startDate])
  @@index([isPublic])
  @@map("events")
}

model TicketType {
  id          String   @id @default(cuid())
  eventId     String   @map("event_id")
  name        String
  description String?
  
  // Pricing
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  
  // Quantity
  quantity    Int      @default(0)
  sold        Int      @default(0)
  
  // Limits
  minPerOrder Int      @default(1) @map("min_per_order")
  maxPerOrder Int      @default(10) @map("max_per_order")
  
  // Sales period
  salesStart  DateTime? @map("sales_start")
  salesEnd    DateTime? @map("sales_end")
  
  // Settings
  isVisible   Boolean  @default(true) @map("is_visible")
  sortOrder   Int      @default(0) @map("sort_order")
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  // Relations
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets Ticket[]
  
  @@index([eventId])
  @@index([isVisible])
  @@map("ticket_types")
}

// ============================================
// Order & Ticket Models
// ============================================

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique @map("order_number")
  
  // Relations
  eventId       String      @map("event_id")
  userId        String?     @map("user_id")
  
  // Customer info (for guest checkout)
  customerEmail String      @map("customer_email")
  customerName  String?     @map("customer_name")
  customerPhone String?     @map("customer_phone")
  
  // Pricing
  subtotal      Decimal     @db.Decimal(10, 2)
  fees          Decimal     @default(0) @db.Decimal(10, 2)
  discount      Decimal     @default(0) @db.Decimal(10, 2)
  tax           Decimal     @default(0) @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  currency      String      @default("USD")
  
  // Status
  status        OrderStatus @default(PENDING)
  
  // Payment
  paymentId     String?     @map("payment_id")
  paymentMethod String?     @map("payment_method")
  paidAt        DateTime?   @map("paid_at")
  
  // Refund
  refundedAt    DateTime?   @map("refunded_at")
  refundAmount  Decimal?    @db.Decimal(10, 2) @map("refund_amount")
  refundReason  String?     @map("refund_reason")
  
  // Metadata
  metadata      Json?       @default("{}")
  notes         String?
  
  // Timestamps
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  expiresAt     DateTime?   @map("expires_at")
  completedAt   DateTime?   @map("completed_at")
  
  // Relations
  event       Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  tickets     Ticket[]
  payments    Payment[]
  auditLogs   AuditLog[]
  
  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@index([customerEmail])
  @@index([createdAt])
  @@map("orders")
}

model Ticket {
  id           String       @id @default(cuid())
  ticketNumber String       @unique @map("ticket_number")
  
  // Relations
  orderId      String       @map("order_id")
  ticketTypeId String       @map("ticket_type_id")
  eventId      String       @map("event_id")
  
  // Attendee info
  attendeeName  String      @map("attendee_name")
  attendeeEmail String      @map("attendee_email")
  attendeePhone String?     @map("attendee_phone")
  
  // QR Code
  qrToken       String      @unique @map("qr_token")
  qrData        String?     @map("qr_data") // Base64 encoded QR image
  
  // Status
  status        TicketStatus @default(ACTIVE)
  
  // Check-in
  checkedIn     Boolean     @default(false) @map("checked_in")
  checkedInAt   DateTime?   @map("checked_in_at")
  checkedInBy   String?     @map("checked_in_by")
  
  // Transfer
  transferredAt DateTime?   @map("transferred_at")
  transferredTo String?     @map("transferred_to")
  
  // PDF
  pdfUrl        String?     @map("pdf_url")
  
  // Timestamps
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  
  // Relations
  order      Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  checkIns   CheckIn[]
  
  @@index([orderId])
  @@index([ticketTypeId])
  @@index([eventId])
  @@index([status])
  @@index([qrToken])
  @@index([attendeeEmail])
  @@map("tickets")
}

model CheckIn {
  id          String   @id @default(cuid())
  ticketId    String   @map("ticket_id")
  eventId     String   @map("event_id")
  
  // Check-in details
  checkedInAt DateTime @default(now()) @map("checked_in_at")
  checkedInBy String   @map("checked_in_by")
  method      CheckInMethod @default(MANUAL)
  
  // Location
  latitude    Float?
  longitude   Float?
  
  // Device info
  deviceId    String?  @map("device_id")
  
  // Relations
  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  @@index([ticketId])
  @@index([eventId])
  @@index([checkedInAt])
  @@map("check_ins")
}

// ============================================
// Payment Models
// ============================================

model Payment {
  id            String        @id @default(cuid())
  orderId       String        @map("order_id")
  
  // Provider info
  provider      PaymentProvider
  providerId    String?       @map("provider_id") // External payment ID
  
  // Amount
  amount        Decimal       @db.Decimal(10, 2)
  currency      String        @default("USD")
  fees          Decimal       @default(0) @db.Decimal(10, 2)
  
  // Status
  status        PaymentStatus @default(PENDING)
  
  // Method details
  method        String?       // card, bank_transfer, etc.
  lastFour      String?       @map("last_four")
  brand         String?       // visa, mastercard, etc.
  
  // Timestamps
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  processedAt   DateTime?     @map("processed_at")
  failedAt      DateTime?     @map("failed_at")
  
  // Error info
  errorCode     String?       @map("error_code")
  errorMessage  String?       @map("error_message")
  
  // Metadata
  metadata      Json?         @default("{}")
  
  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  @@index([orderId])
  @@index([provider])
  @@index([status])
  @@index([providerId])
  @@map("payments")
}

// ============================================
// Template System
// ============================================

model Template {
  id             String         @id @default(cuid())
  organizationId String         @map("organization_id")
  
  name           String
  description    String?
  type           TemplateType
  
  // Content
  subject        String?        // For email templates
  content        String         @db.Text
  styles         Json?          @default("{}")
  
  // Settings
  isDefault      Boolean        @default(false) @map("is_default")
  
  // Timestamps
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  
  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events       Event[]
  
  @@unique([organizationId, type, isDefault], name: "unique_default_template")
  @@index([organizationId])
  @@index([type])
  @@map("templates")
}

// ============================================
// Webhook System
// ============================================

model Webhook {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  createdById    String   @map("created_by_id")
  
  name           String
  url            String
  secret         String   // For signature verification
  
  // Events to subscribe to
  events         WebhookEvent[]
  
  // Status
  isActive       Boolean  @default(true) @map("is_active")
  
  // Timestamps
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  
  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  deliveries   WebhookDelivery[]
  
  @@index([organizationId])
  @@index([isActive])
  @@map("webhooks")
}

model WebhookDelivery {
  id        String   @id @default(cuid())
  webhookId String   @map("webhook_id")
  
  event     WebhookEvent
  payload   Json
  
  // Request/Response
  requestHeaders  Json?   @map("request_headers")
  responseBody    String? @map("response_body")
  responseStatus  Int?    @map("response_status")
  
  // Status
  status    WebhookDeliveryStatus @default(PENDING)
  
  // Retry info
  attempt   Int      @default(0)
  maxAttempts Int    @default(3) @map("max_attempts")
  nextRetryAt DateTime? @map("next_retry_at")
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  completedAt DateTime? @map("completed_at")
  
  // Relations
  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  
  @@index([webhookId])
  @@index([status])
  @@index([createdAt])
  @@map("webhook_deliveries")
}

// ============================================
// API Keys
// ============================================

model ApiKey {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  
  name           String
  keyHash        String    @unique @map("key_hash")
  keyPrefix      String    @map("key_prefix") // First 8 chars for display
  
  // Permissions
  permissions    String[]  @default([])
  
  // Usage
  lastUsedAt     DateTime? @map("last_used_at")
  usageCount     Int       @default(0) @map("usage_count")
  
  // Expiration
  expiresAt      DateTime? @map("expires_at")
  
  // Status
  isRevoked      Boolean   @default(false) @map("is_revoked")
  revokedAt      DateTime? @map("revoked_at")
  revokedReason  String?   @map("revoked_reason")
  
  // Timestamps
  createdAt      DateTime  @default(now()) @map("created_at")
  
  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  @@index([organizationId])
  @@index([keyHash])
  @@map("api_keys")
}

// ============================================
// Audit Logging
// ============================================

model AuditLog {
  id          String   @id @default(cuid())
  
  // Actor
  userId      String?  @map("user_id")
  userEmail   String?  @map("user_email")
  userIp      String?  @map("user_ip")
  userAgent   String?  @map("user_agent")
  
  // Action
  action      String   // e.g., "order.created", "ticket.checked_in"
  entityType  String   @map("entity_type") // e.g., "order", "ticket"
  entityId    String?  @map("entity_id")
  
  // Context
  organizationId String? @map("organization_id")
  eventId        String? @map("event_id")
  orderId        String? @map("order_id")
  
  // Data
  before      Json?    // Previous state
  after       Json?    // New state
  metadata    Json?    // Additional context
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")
  
  // Relations
  user  User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  
  @@index([userId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([organizationId])
  @@index([eventId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// Enums
// ============================================

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum OrganizationMemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum OrderStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
  EXPIRED
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELLED
  REFUNDED
  TRANSFERRED
}

enum PaymentProvider {
  STRIPE
  PAYPAL
  MANUAL
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum TemplateType {
  EMAIL_ORDER_CONFIRMATION
  EMAIL_TICKET
  EMAIL_EVENT_REMINDER
  PDF_TICKET
}

enum WebhookEvent {
  ORDER_CREATED
  ORDER_COMPLETED
  ORDER_CANCELLED
  ORDER_REFUNDED
  TICKET_CREATED
  TICKET_CHECKED_IN
  TICKET_TRANSFERRED
  EVENT_PUBLISHED
  EVENT_CANCELLED
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
  RETRYING
}

enum CheckInMethod {
  MANUAL
  QR_SCAN
  APP
}
