# ============================================
# Ticketing Platform - Environment Configuration
# ============================================

# Copy this file to .env and fill in your values

# ============================================
# Database (PostgreSQL)
# ============================================
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=ticketing
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# ============================================
# Valkey (Redis-compatible)
# ============================================
VALKEY_URL=redis://localhost:6379

# ============================================
# Session
# ============================================
# REQUIRED — generate with: openssl rand -base64 48
SESSION_SECRET=

# ============================================
# Application URLs
# ============================================
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# ============================================
# CORS Origins (comma-separated)
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ============================================
# Stripe (Payment Processing)
# ============================================
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# Email (Resend)
# ============================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Your Event Platform

# ============================================
# Object Storage (MinIO/S3)
# ============================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=${MINIO_ROOT_USER}
S3_SECRET_KEY=${MINIO_ROOT_PASSWORD}
S3_BUCKET=ticketing
S3_REGION=us-east-1

# ============================================
# Provider Selection
# ============================================
# Choose which backend adapter to use for each service.
# See ROADMAP.md §0.4 for the full list of supported values.
PAYMENT_PROVIDER=manual
EMAIL_PROVIDER=console
STORAGE_PROVIDER=local

# ============================================
# Zeffy (Payment — zero-fee for non-profits)
# ============================================
# Required when PAYMENT_PROVIDER=zeffy
ZEFFY_FORM_BASE_URL=
ZEFFY_WEBHOOK_SECRET=

# ============================================
# Docker / Deployment
# ============================================
DOCKER_REGISTRY=ghcr.io/yourusername
TAG=latest

# ============================================
# Optional: Monitoring & Analytics
# ============================================
# SENTRY_DSN=
# POSTHOG_KEY=
